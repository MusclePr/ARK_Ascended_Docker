# cluster default common env

# Time Zone
TZ=Asia/Tokyo

# Passwords
ARK_ADMIN_PASSWORD=MyArkAdminPassword
SERVER_PASSWORD=

# If you want MOD-aware checks in automatic update, specify your CurseForge API key.
# MOD checks run only when AUTO_UPDATE_ENABLED=true and MODS has valid numeric IDs.
# You can get an API key at https://console.curseforge.com/
CURSEFORGE_API_KEY=

# Backup & Update using master(main) only
AUTO_BACKUP_ENABLED=false
AUTO_UPDATE_ENABLED=false

# Defaults
DISABLE_BATTLEYE=1
MAX_PLAYERS=10
RCON_PORT=27020
# SteamCMD target platform for app_update (ASA dedicated server currently requires windows)
# STEAMCMD_PLATFORM=windows

# Mods: comma-separated CurseForge mod IDs.
# This list is used both for server startup (-mods=...) and MOD update checks.
# e.g. MODS=931872,931338
MODS=
ALL_MODS=929800,929420,935408,928793,933975,929578,930494,933447,941697,935528,936145,1002660,929785,930381,928708

# Enable ServerGameLog
SERVERGAMELOG=true

# Cluster
# Must be changed to a unique non-empty value. Startup fails if empty or left as GlobalUniqueClusterID.
CLUSTER_ID=GlobalUniqueClusterID

# Use Dynamic Config
DYNAMIC_CONFIG_URL=http://asa_config/dynamicconfig.ini

ARK_EXTRA_DASH_OPTS=-exclusivejoin -ForceRespawnDinos -AllowRaidDinoFeeding=true -ServerPlatform=ALL
ARK_EXTRA_OPTS=?ServerCrosshair=true?OverrideStructurePlatformPrevention=true?OverrideOfficialDifficulty=5.0?ShowFloatingDamageText=true?AllowFlyerCarryPvE=true

# Discord Messages
DISCORD_MSG_JOINED="%s has joined"
DISCORD_MSG_LEFT="%s has left"
DISCORD_MSG_STARTING="The Server is starting"
DISCORD_MSG_UP="The Server is up"
DISCORD_MSG_STOPPING="Server will gracefully shutdown"
DISCORD_MSG_FORCE_SHUTDOWN="Forcing the Server to shutdown"
DISCORD_MSG_STOPPED="The Server has been stopped"
DISCORD_MSG_RESTARTING="The Server is restarting"
DISCORD_MSG_PAUSED="The Server has been paused"
DISCORD_MSG_RESUMED="The Server has been resumed"

# Auto pause settings
AUTO_PAUSE_ENABLED=true
#AUTO_PAUSE_IDLE_MINUTES=3
