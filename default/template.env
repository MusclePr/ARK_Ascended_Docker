# Master Server Settings
ASA0_CLUSTER_NODES=2
ASA0_AUTO_BACKUP_ENABLED=true
ASA0_AUTO_BACKUP_CRON_EXPRESSION="0 3 * * *"
ASA0_AUTO_UPDATE_ENABLED=true
ASA0_AUTO_UPDATE_CRON_EXPRESSION="0 4 * * 0"
